{
  "license": "ISC",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts",
    "launch:game": "ts-node --transpile-only scripts/launch-game.ts",
    "launch:game:create": "ts-node --transpile-only scripts/launch-game.ts create",
    "launch:game:delegate": "ts-node --transpile-only scripts/launch-game.ts delegate-game",
    "launch:game:status": "ts-node --transpile-only scripts/launch-game.ts status",
    "launch:game:quick": "LAUNCH_DURATION_SECONDS=300 LAUNCH_MAX_PLAYERS=3 ts-node --transpile-only scripts/launch-game.ts create",
    "mcp:build": "tsc -p services/user-mcp/tsconfig.json",
    "mcp:serve": "node dist/user-mcp/index.js",
    "mcp:agent-game": "ts-node --transpile-only scripts/run-mcp-agent-game.ts",
    "launch:rehearsal": "ts-node --transpile-only scripts/run-mcp-agent-game.ts",
    "mcp:test": "ts-mocha -p services/user-mcp/tsconfig.test.json -t 60000 'services/user-mcp/tests/**/*.ts'",
    "mcp:test:live": "TRADE_ARENA_RUN_LIVE_TESTS=1 ts-mocha -p services/user-mcp/tsconfig.test.json -t 120000 'services/user-mcp/tests/live-integration.test.ts'"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.6.5",
    "@modelcontextprotocol/sdk": "1.10.2",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^20",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
