{
  "compilerOptions": {
    "outDir": "../../dist/user-mcp",
    "rootDir": "src",
    "types": ["node"],
    "lib": ["ES2022"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2020",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
